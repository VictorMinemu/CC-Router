{
  "name": "ai-cc-router",
  "version": "0.1.10",
  "description": "Round-robin proxy for Claude Max OAuth tokens — use multiple Claude Max accounts with Claude Code",
  "type": "module",
  "bin": {
    "cc-router": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "anthropic",
    "proxy",
    "oauth",
    "round-robin",
    "claude-code",
    "claude-max"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VictorMinemu/CC-Router.git"
  },
  "bugs": {
    "url": "https://github.com/VictorMinemu/CC-Router/issues"
  },
  "homepage": "https://github.com/VictorMinemu/CC-Router#readme",
  "files": [
    "dist/",
    "litellm-config.yaml",
    "docker-compose.yml",
    "Dockerfile",
    "accounts.example.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.5",
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
